# Copy to .env and fill in real values. The app refuses to start if the
# secrets below are unset (no insecure defaults).

# Secret used to sign JWT session tokens (use a long random string).
JWT_SECRET_KEY=

# Secret mixed into the token hash used for QR/emergency lookups.
ENCRYPTION_KEY=

# SQLAlchemy database URL. Defaults to local SQLite if unset.
# Postgres example: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./test.db

# Comma-separated list of origins allowed by CORS (the frontend URLs).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
